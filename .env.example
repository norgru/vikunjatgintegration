NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

TELEGRAM_BOT_TOKEN=
# Numeric group/supergroup ID, normally beginning with -100.
TELEGRAM_CHAT_ID=
# Optional forum topic ID. Leave unset to use the whole group.
# TELEGRAM_MESSAGE_THREAD_ID=

# Include /api/v1, for example https://tasks.example.com/api/v1
VIKUNJA_API_URL=
# Browser-facing URL, without /api/v1
VIKUNJA_FRONTEND_URL=
VIKUNJA_API_TOKEN=
VIKUNJA_PROJECT_ID=
# Use a random value of at least 16 characters and enter the same value in Vikunja.
VIKUNJA_WEBHOOK_SECRET=

# Name of the existing Docker network shared with Vikunja; used by compose.yaml.
VIKUNJA_DOCKER_NETWORK=vikunja_default
